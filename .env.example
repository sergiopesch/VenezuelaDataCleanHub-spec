VDCH_DATABASE_URL=postgresql+psycopg://vdch:vdch@localhost:5432/vdch
VDCH_DEV_AUTH_ENABLED=true
VDCH_TEMPORAL_ENABLED=false
VDCH_TEMPORAL_ADDRESS=localhost:7233
VDCH_OPA_ENABLED=false
VDCH_ALLOW_POLICY_BYPASS_FOR_LOCAL_DEV=true
VDCH_OPA_URL=http://localhost:8181/v1/data/vdch/allow
VDCH_ALLOW_SAMPLE_MANIFESTS=true
VDCH_MANIFEST_HOST_ALLOWLIST=api.example.org
VDCH_FINGERPRINT_SECRET=replace-this-local-dev-secret
VDCH_ALLOW_INSECURE_FINGERPRINTS_FOR_LOCAL_DEV=false
VDCH_MAX_MATCH_BLOCK_SIZE=1000
